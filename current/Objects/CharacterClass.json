            "Key": "Class_Assault_name",
            "TableNamespace": "ST_C_Classes",
            "en": "Assault"
        },
        "description": {
            "Key": "Class_Assault_descr",
            "TableNamespace": "ST_C_Classes",
            "en": "Assaults are designed for frontal attacks and mid-range firefights.  They carry powerful weapons and can hold out in open confrontations for long periods. Their shields start regenerating faster than other classes, and their armor is strong enough to take a lot of damage."
        },
