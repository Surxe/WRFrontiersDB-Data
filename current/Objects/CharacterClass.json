    "DA_CharacterClass_Flanker.0": {
        "id": "DA_CharacterClass_Flanker.0",
        "name": {
            "Key": "Class_Flanker_name",
            "TableNamespace": "ST_C_Classes",
            "en": "Flanker"
        },
        "description": {
            "Key": "Class_Flanker_descr",
            "TableNamespace": "ST_C_Classes",
            "en": "Flankers are fast robots that work best as scouts or assassins. Their speed allows them to move quickly across the map, capture unguarded Warp Gates, or conduct hit-and-run attacks from the sidelines."
        },
