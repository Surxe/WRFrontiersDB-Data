    "DA_CharacterClass_Tactician.0": {
        "id": "DA_CharacterClass_Tactician.0",
        "name": {
            "Key": "Class_Tactitian_name",
            "TableNamespace": "ST_C_Classes",
            "en": "Tactician"
        },
        "description": {
            "Key": "Class_Tactician_descr",
            "TableNamespace": "ST_C_Classes",
            "en": "Tacticians are backline robots that are designed to weaken enemies and support allies with ranged fire, thus helping to control the battlefield. Their components are lighter than other classes, while their high speed and large fuel capacity allow them to occupy positions inaccessible to other robots."
        },
